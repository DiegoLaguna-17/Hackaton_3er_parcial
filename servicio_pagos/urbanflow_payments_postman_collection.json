    {
      "name": "Métodos de Pago",
      "item": [
        {
          "name": "Registrar Tarjeta NFC / QR",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.payment_method) {",
                  "    pm.environment.set(\"payment_method_id\", response.payment_method.id);",
                  "    pm.environment.set(\"payment_token\", response.payment_method.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wallet_id\": \"{{wallet_id}}\",\n  \"method_type\": \"nfc_card\",\n  \"label\": \"Mi tarjeta NFC prepago\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payment-methods",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payment-methods"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Listar Métodos de Billetera",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/payment-methods/{{wallet_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payment-methods",
                "{{wallet_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Validar Token de Pago (Simular Tap NFC)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{payment_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payment-methods/validate-token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payment-methods",
                "validate-token"
              ]
            }
          },
          "response": []
        }
      ]
